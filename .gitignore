# ============================================================
# .gitignore – RcTracking (Shopware 6 Plugin)
# ============================================================

# ============================================================
# PHP / Composer
# ============================================================
/vendor/
composer.lock
*.phar

# ============================================================
# Shopware Plugin Build
# ============================================================
*.zip
/node_modules/
/public/
/.pnpm-store/

# ============================================================
# Shopware Cache / Runtime
# ============================================================
/var/
/var/cache/
/var/log/

# ============================================================
# Secrets / Umgebung (NIEMALS in Git!)
# ============================================================
.env
.env.local
.env.*.local
!.env.example
*.secret
config/packages/secrets/

# ============================================================
# Test-Ergebnisse
# ============================================================
.phpunit.result.cache
/coverage/
/report/

# ============================================================
# IDE & Betriebssystem
# ============================================================
.idea/
.vscode/
*.DS_Store
Thumbs.db
desktop.ini
.phpstorm.meta.php
_ide_helper.php

# ============================================================
# Reviews (lokale Arbeitsmittel, nicht in Git)
# ============================================================
/reviews/

# ============================================================
# Logs
# ============================================================
*.log
/logs/

