{
    "name": "ruhrcoder/rc-tracking",
    "description": "DSGVO-konformes Tracking-Plugin für Shopware 6.7 (GTM, Microsoft UET, Custom Code)",
    "type": "shopware-platform-plugin",
    "license": "MIT",
    "version": "1.1.0",
    "authors": [
        {
            "name": "Ruhrcoder",
            "homepage": "https://ruhrcoder.de"
        }
    ],
    "require": {
        "shopware/core": "~6.7.0 || ~6.8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Ruhrcoder\\RcTracking\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ruhrcoder\\RcTracking\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "quality": [
            "@cs-check",
            "@phpstan",
            "@test"
        ]
    },
    "extra": {
        "shopware-plugin-class": "Ruhrcoder\\RcTracking\\RcTracking",
        "label": {
            "de-DE": "Tracking (GTM, UET)",
            "en-GB": "Tracking (GTM, UET)"
        },
        "description": {
            "de-DE": "DSGVO-konformes Plugin zur zentralen Verwaltung von Tracking-Skripten: Google Tag Manager, Microsoft UET und benutzerdefinierter Code mit Consentmanager-Integration.",
            "en-GB": "GDPR-compliant plugin for central management of tracking scripts: Google Tag Manager, Microsoft UET and custom code with consent manager integration."
        }
    }
}
